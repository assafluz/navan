# Copy this file to ".env" and set values. ".env" is gitignored — never commit secrets.
#
#   cp .env.example .env

# ReqRes — required if their API returns missing_api_key (https://app.reqres.in/api-keys)
REQRES_API_KEY=

# Optional: override users endpoint if your project uses another base URL
# REQRES_USERS_URL=https://reqres.in/api/users

# Optional: slow Playwright when using pytest --headed
# PLAYWRIGHT_SLOW_MO=500
